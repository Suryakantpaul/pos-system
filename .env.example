# ─────────────────────────────────────────────
#  Omnichannel POS — Environment Configuration
# ─────────────────────────────────────────────

# API Base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:5000/api

# App metadata
VITE_APP_NAME="RetailOS POS"
VITE_APP_VERSION=1.0.0

# Tax rate (decimal, e.g. 0.08 = 8%)
VITE_TAX_RATE=0.08

# Offline sync interval in ms (default 30s)
VITE_SYNC_INTERVAL=30000

# Feature flags
VITE_ENABLE_BARCODE_SCANNER=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_ROLE_BASED_UI=true

# Redis / Cache TTL (seconds) — backend ref
VITE_CACHE_TTL=300
